# Railway / Node
PORT=3000
NODE_ENV=production

# Telegram
BOT_TOKENS=123456:ABCDEF
CHAT_IDS=123456789
TELEGRAM_ENABLED=true
# false = un solo messaggio operativo; audit completo resta in log/endpoint
TELEGRAM_AUDIT_DETAILS=false

# Mercato Bybit perpetual
MARKET_MODE=linear
BYBIT_CATEGORY=linear

# Simboli e timeframe
COINS=BTCUSDT
INTERVALS=3m,5m,15m,30m,1h

# Loop / API
SCAN_INTERVAL_MS=60000
REQUEST_DELAY_MS=150
HTTP_TIMEOUT_MS=15000
RETRY_COUNT=2

# Logica segnale a maggioranza: almeno 2 pilastri su 3
# Pilastri: Range Box fresco, TL fresca, Liquidity multi-exchange
SIGNAL_MIN_PILLARS=2
ENABLE_RANGEBOX_SIGNAL=true
ENABLE_LUX_TL_SIGNAL=true

# BR Range Box
RANGE_LOOKBACK=20
# 0 = conta come pilastro verde soltanto se rotto sulla candela corrente
RANGE_BREAK_MAX_AGE_CANDLES=0

# Trendline LuxAlgo portata in Node
# 0 = conta come pilastro verde soltanto se rotta sulla candela corrente
TL_BREAK_MAX_AGE_CANDLES=0
LUX_LENGTH=14
LUX_SLOPE_MULT=1
LUX_CALC_METHOD=Atr

# Memoria rotture e retest, separata per simbolo + timeframe + direzione
RANGE_BREAK_MEMORY_BARS=20
TL_BREAK_MEMORY_BARS=20
RETEST_TOLERANCE_PCT=0.10
RETEST_CONFIRM_ON_CLOSE=true
# false consigliato: retest/rottura recente è gialla e informativa, non nuova spunta verde
COUNT_RETEST_AS_PILLAR=false
# Rottura invalidata dopo 2 chiusure stabili dal lato opposto
BREAK_INVALIDATION_CLOSES=2
BREAK_INVALIDATION_TOLERANCE_PCT=0.05

# Order book / Liquidity Engine: Bybit + Binance + OKX
ORDERBOOK_LIMIT=50
TRADE_LIMIT=100
TOP_BOOK_LEVELS=10
STRONGEST_WALL_MAX_DISTANCE_PCT=1.25
EXCHANGE_REQUIRED_CONFIRMATIONS=2
MIN_SPREAD_OK_PCT=0.08
MIN_BOOK_VELOCITY_ACTIVE=0.35
DEBUG_REJECTED_SIGNALS=true

# Auto Cluster sempre visibile nel messaggio
AUTO_CLUSTER_MAX_DISTANCE_PCT=2.5
AUTO_CLUSTER_MERGE_TOLERANCE_PCT=0.20
AUTO_CLUSTER_LEVELS_ABOVE=3
AUTO_CLUSTER_LEVELS_BELOW=3

# Entry / warning
NO_CHASE_ENTRY_RANGE_PCT=0.12
ENTRY_NEAR_BREAK_PCT=0.05
# Pivot vicino = cartello fake-break; NON blocca la notifica
PIVOT_WARNING_DISTANCE_PCT=0.20

# Supporti/Resistenze EzAlgo V.5, separati per ogni timeframe
SR_PIVOT_LEFT=50
SR_PIVOT_RIGHT=25
SR_QUICK_RIGHT=5
SR_LEVELS_ABOVE=3
SR_LEVELS_BELOW=3
SR_MERGE_TOLERANCE_PCT=0.05
