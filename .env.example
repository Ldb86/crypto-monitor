# ============================================
# CRYPTO-MONITOR - Environment Configuration
# ============================================

# Telegram Configuration
# Separate multiple BOT_TOKENS and CHAT_IDS with commas
BOT_TOKENS=bot_token_1,bot_token_2,bot_token_3
CHAT_IDS=chat_id_1,chat_id_2,chat_id_3

# Server Port (default 3000)
PORT=3000

# ============================================
# Note: Each microservice can run on different ports
# using PORT environment variable or .env file
# ============================================
